# =========================================================================
# VaidyaGraph - Environment variables
# =========================================================================
# Copy this file to `.env` and fill in the values. `.env` is read once at
# process startup via core/config.py.
#
#   Copy-Item .env.example .env     (PowerShell)
#   cp .env.example .env            (bash)
#
# =========================================================================

# -- Chutes AI (OpenAI-compatible endpoint) -------------------------------
# Required. Get your key from https://chutes.ai
CHUTES_API_KEY=your_chutes_api_key_here

# Base URL. Default is correct for hosted Chutes; override only if you're
# running a self-hosted OpenAI-compatible gateway.
CHUTES_BASE_URL=https://llm.chutes.ai/v1

# -- Model -----------------------------------------------------------------
# Qwen3-32B-TEE is the tested, reliable default for this project - it
# consistently returns well-structured markdown within our 180s timeout.
#
# Llama-3-70B-Instruct is slower and often times out on busy Chutes nodes;
# use it only if you know the endpoint is warm.
MODEL_NAME=Qwen/Qwen3-32B-TEE
# MODEL_NAME=meta-llama/Meta-Llama-3-70B-Instruct

# -- ChromaDB (reserved for RAG extensions) -------------------------------
CHROMA_PERSIST_DIR=./chroma_db
